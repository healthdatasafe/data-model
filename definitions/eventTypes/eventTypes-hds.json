    },
    "settings/unit-system": {
      "description": "Preferred measurement unit system",
      "type": "string",
      "enum": ["metric", "imperial"]
    },
    "contact/display-name": {
      "description": "User display name",
      "type": "string"
    },
    "delivery/composite-v1": {
      "description": "Per-baby delivery / birth event. One event per baby; siblings of multifetal pregnancies share event.time (= delivery date) and typically share 'mode'. Stillbirth status is carried upstream on fertility-pregnancy.outcome=stillbirth, NOT here. Field vocabularies aligned to LOINC: 73762-7 (mode), 8339-4 (birth weight), 76689-9 (sex assigned at birth), 9274-2 (5-min APGAR).",
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "description": "Final route and method of delivery (LOINC 73762-7 / US Standard Certificate of Live Birth).",
          "type": "string",
          "enum": ["vaginal-spontaneous", "vaginal-forceps", "vaginal-vacuum", "cesarean", "unknown"]
        },
        "birthWeight": {
          "description": "Birth weight in grams (LOINC 8339-4).",
          "type": "number",
          "minimum": 0
        },
        "sex": {
          "description": "Sex assigned at birth (LOINC 76689-9). 'indeterminate' covers ambiguous genitalia / disorders of sex development.",
          "type": "string",
          "enum": ["male", "female", "indeterminate", "unknown"]
        },
        "apgar5min": {
          "description": "APGAR score at 5 minutes (LOINC 9274-2), integer 0–10.",
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "nicuLengthOfStayDays": {
          "description": "Length of NICU admission in days; 0 if not admitted.",
          "type": "number",
          "minimum": 0
        },
        "neonatalDeathDays": {
          "description": "Days from delivery to neonatal death (within 28 days post-livebirth). Absent / null = alive at last follow-up.",
          "type": "number",
          "minimum": 0,
          "maximum": 28
        }
      }
    },
    "cervix-position/3d-vectors": {
      "description": "Cervical position observation as up to four 0–1 vectors: height (low→high), firmness (firm→soft), openness (closed→open) follow the SHOW fertility direction (0 = least fertile, 1 = most fertile). Optional tilt (straight→tilted) is a position-only field, not a fertility signal — RYB-originated; no clinical-coding convention exists.",
      "type": "object",
      "properties": {
        "height": {
          "description": "Cervix height: 0 = low, 0.5 = medium, 1 = high",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "firmness": {
          "description": "Cervix firmness: 0 = firm, 0.5 = medium, 1 = soft",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "openness": {
          "description": "Cervical os openness: 0 = closed, 0.5 = medium, 1 = open",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "tilt": {
          "description": "Cervix tilt: 0 = straight, 0.5 = medium, 1 = tilted. Position-only — not a fertility signal. Added in body-vulva-cervix-position v2 (RYB-originated; no clinical-coding convention).",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "mood/5d-vectors": {
      "description": "Mood observation as five 0–1 dimensional vectors based on Russell's Circumplex and PAD models. Content is { vectors, source? }. Used with the euclidian-distance converter engine.",
      "type": "object",
      "properties": {
        "vectors": {
          "description": "5-dimensional mood vector (each dimension 0.0–1.0)",
          "type": "object",
          "properties": {
            "valence": {
              "description": "Pleasure/displeasure: 0 = very unpleasant, 0.5 = neutral, 1 = very pleasant",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "arousal": {
              "description": "Energy/activation: 0 = very calm, 0.5 = moderate, 1 = very activated",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "dominance": {
              "description": "Sense of control: 0 = powerless, 0.5 = neutral, 1 = in control",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "socialOrientation": {
              "description": "Social focus: 0 = self-focused, 0.5 = balanced, 1 = other-focused",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "temporalFocus": {
              "description": "Time orientation: 0 = past-dwelling, 0.5 = present, 1 = future-anticipating",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "source": {
          "description": "Provenance: which method produced this vector. Absent = direct vector input.",
          "type": "object",
          "properties": {
            "key": { "type": "string", "description": "Source method identifier (e.g. mira, hds, descriptive)" },
            "sourceData": { "description": "Raw observation from the source method" },
            "engineVersion": { "type": "string", "description": "Converter engine version used" },
            "modelVersion": { "type": "string", "description": "Model definition version used" }
          }
        }
      },
      "required": ["vectors"]
    },
    "message/system-alert": {
      "description": "Operator → user notification on app-system-out. Content: { level, title, body, ackRequired?, ackId? }. Plan 45.",
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "title", "body"],
      "properties": {
        "level": {
          "description": "Severity: info / warning / critical",
          "type": "string",
          "enum": ["info", "warning", "critical"]
        },
        "title": {
          "description": "Short heading (max 200 chars)",
          "type": "string",
          "maxLength": 200
        },
        "body": {
          "description": "Body text (max 4000 chars)",
          "type": "string",
          "maxLength": 4000
        },
        "ackRequired": {
          "description": "If true, the user's app surfaces an Acknowledge button and the operator expects a matching message/system-ack",
          "type": "boolean"
        },
        "ackId": {
          "description": "UUID generated by the operator at post time. Echoed in the matching message/system-ack to link the response.",
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "message/system-ack": {
      "description": "User → operator acknowledgement of a message/system-alert, paired by ackId. Plan 45.",
      "type": "object",
      "additionalProperties": false,
      "required": ["ackId", "ackedAt"],
      "properties": {
        "ackId": {
          "description": "Matches the message/system-alert.ackId being acknowledged",
          "type": "string",
          "format": "uuid"
        },
        "ackedAt": {
          "description": "ISO-8601 timestamp at which the user clicked Acknowledge",
          "type": "string",
          "format": "date-time"
        },
        "userNote": {
          "description": "Optional free-text note from the user (max 1000 chars)",
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "questionnaire/request-v1": {
      "description": "Doctor (or generator) → patient: a questionnaire instantiated for this patient. Carries a 'questions' map keyed by stable question keys. Each question references an existing HDS item (itemRef) with optional entity filter (params), a temporal scope (ever / window / latest with withinDays), and an optional subField for qualifier capture. The patient's matching questionnaire/answer-v1 event carries the answers map keyed by the same question keys and links back via requestEventId. Question keys must match Pryv content-query path grammar [a-zA-Z0-9_-]+ so content.answers.<key>.status queries work. See documentation/QUESTIONNAIRE.md.",
      "type": "object",
      "additionalProperties": false,
      "required": ["questions"],
      "properties": {
        "title": {
          "description": "Optional localized title shown to the patient",
          "type": "object",
          "properties": {
            "en": { "type": "string" }
          }
        },
        "description": {
          "description": "Optional localized description / instructions shown above the questionnaire",
          "type": "object",
          "properties": {
            "en": { "type": "string" }
          }
        },
        "templateRef": {
          "description": "Optional reference to a saved hds-lib appTemplates Questionnaire definition that this request was generated from",
          "type": "string"
        },
        "questions": {
          "description": "Map of questionKey → question definition. Keys must respect the Pryv content-query path grammar [a-zA-Z0-9_-]+ — no colons, dots, or array indices.",
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label", "itemRef", "scope"],
            "properties": {
              "label": {
                "description": "Localized question text shown to the patient",
                "type": "object",
                "properties": {
                  "en": { "type": "string" }
                }
              },
              "itemRef": {
                "description": "Key of an existing HDS item (data-model items registry) that defines storage shape + renderer for the answer's referenced events",
                "type": "string"
              },
              "params": {
                "description": "Optional filter narrowing the question to a specific entity (e.g. { drug: { codes: [...] } } for a medication question). Shape is interpreted by the referenced item's renderer.",
                "type": "object"
              },
              "scope": {
                "description": "Temporal scope evaluated by the renderer for prefill / matching event lookup",
                "type": "object",
                "required": ["type"],
                "oneOf": [
                  {
                    "additionalProperties": false,
                    "properties": {
                      "type": { "const": "ever" }
                    }
                  },
                  {
                    "additionalProperties": false,
                    "required": ["type", "withinDays"],
                    "properties": {
                      "type": { "const": "window" },
                      "withinDays": { "type": "number", "exclusiveMinimum": 0 }
                    }
                  },
                  {
                    "additionalProperties": false,
                    "required": ["type", "withinDays"],
                    "properties": {
                      "type": { "const": "latest" },
                      "withinDays": { "type": "number", "exclusiveMinimum": 0 }
                    }
                  }
                ]
              },
              "subField": {
                "description": "Optional qualifier capture rendered alongside the answer when status is 'answered'. Stored as 'qualifier' on the answer entry.",
                "type": "object",
                "additionalProperties": false,
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["select-segmented", "text", "number"]
                  },
                  "label": {
                    "type": "object",
                    "properties": {
                      "en": { "type": "string" }
                    }
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "label"],
                      "properties": {
                        "value": { "type": ["number", "string"] },
                        "label": {
                          "type": "object",
                          "properties": {
                            "en": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "questionnaire/answer-v1": {
      "description": "Patient → doctor: the response to a questionnaire/request-v1. 'requestEventId' links back to the request event. 'answers' is a map keyed by the same question keys as the request; key absence means 'not-answered' (skipped / unreached). Each answer entry carries a 'status' enum (answered / no / unknown / declined) with conditional fields per status. Referenced event ids in 'answered' entries must ALSO be mirrored into clientData.related.<eventId>: true per the Pryv §7 keyed-object cross-reference convention so cohort queries can use the indexed clientData parameter. See documentation/QUESTIONNAIRE.md.",
      "type": "object",
      "additionalProperties": false,
      "required": ["requestEventId", "answers"],
      "properties": {
        "requestEventId": {
          "description": "eventId of the questionnaire/request-v1 event being answered",
          "type": "string",
          "minLength": 1
        },
        "answers": {
          "description": "Map of questionKey → answer entry. Keys present here MUST correspond to questions in the linked request. Key absence = implicit 'not-answered' (skipped or unreached).",
          "type": "object",
          "propertyNames": {
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "additionalProperties": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["status", "references"],
                "properties": {
                  "status": { "const": "answered" },
                  "references": {
                    "description": "eventIds of the typed events that satisfy this question. Non-empty. Each id MUST also appear as a key in clientData.related (with value true) on the same event.",
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string", "minLength": 1 }
                  },
                  "qualifier": {
                    "description": "Optional sub-field value (trimester, free text, number, etc.). Shape interpreted by the request's subField declaration."
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["status"],
                "properties": {
                  "status": { "const": "no" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["status"],
                "properties": {
                  "status": { "const": "unknown" }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["status"],
                "properties": {
                  "status": { "const": "declined" },
                  "reason": {
                    "description": "Optional free-text reason for declining to answer (v1). Future additive extension may accept a coded value (e.g. SNOMED 715169006 'Declined to disclose information').",
                    "type": "string"
                  }
                }
              }
            ]
          }
        }
      }
    }
  },
