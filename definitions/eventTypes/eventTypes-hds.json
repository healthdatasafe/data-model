    "frequency/times-period": {
      "description": "Number of times per period. E.g. 2 times per day, 1 time per week.",
      "type": "object",
      "required": ["times", "period", "periodUnit"],
      "properties": {
        "times": {
          "description": "Number of intakes per period (e.g. 2 for 'twice a day')",
          "type": "number",
          "minimum": 1
        },
        "period": {
          "description": "Length of the period (e.g. 1 for 'per day', 8 for 'every 8 hours')",
          "type": "number",
          "minimum": 1
        },
        "periodUnit": {
          "description": "Unit of the period",
          "type": "string",
          "enum": ["h", "d", "wk", "mo", "y"]
        }
      }
    },
    "settings/preferred-locales": {
      "description": "User preferred locales, ordered by priority",
      "type": "array",
      "items": { "type": "string" }
    },
    "settings/theme": {
      "description": "UI theme preference",
      "type": "string",
      "enum": ["light", "dark"]
    },
    "settings/timezone": {
      "description": "User timezone (IANA identifier)",
      "type": "string"
    },
    "settings/date-format": {
      "description": "Preferred date display format",
      "type": "string",
      "enum": ["DD.MM.YYYY", "DD/MM/YYYY", "MM/DD/YYYY", "YYYY-MM-DD"]
    },
    "settings/unit-system": {
      "description": "Preferred measurement unit system",
      "type": "string",
      "enum": ["metric", "imperial"]
    },
    "contact/display-name": {
      "description": "User display name",
      "type": "string"
    },
    "cervix-position/3d-vectors": {
      "description": "Cervical position observation as three 0–1 vectors: height (low→high), firmness (firm→soft), openness (closed→open). Each dimension follows the fertility direction (0 = least fertile, 1 = most fertile).",
      "type": "object",
      "properties": {
        "height": {
          "description": "Cervix height: 0 = low, 0.5 = medium, 1 = high",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "firmness": {
          "description": "Cervix firmness: 0 = firm, 0.5 = medium, 1 = soft",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "openness": {
          "description": "Cervical os openness: 0 = closed, 0.5 = medium, 1 = open",
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "mood/5d-vectors": {
      "description": "Mood observation as five 0–1 dimensional vectors based on Russell's Circumplex and PAD models. Content is { vectors, source? }. Used with the euclidian-distance converter engine.",
      "type": "object",
      "properties": {
        "vectors": {
          "description": "5-dimensional mood vector (each dimension 0.0–1.0)",
          "type": "object",
          "properties": {
            "valence": {
              "description": "Pleasure/displeasure: 0 = very unpleasant, 0.5 = neutral, 1 = very pleasant",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "arousal": {
              "description": "Energy/activation: 0 = very calm, 0.5 = moderate, 1 = very activated",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "dominance": {
              "description": "Sense of control: 0 = powerless, 0.5 = neutral, 1 = in control",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "socialOrientation": {
              "description": "Social focus: 0 = self-focused, 0.5 = balanced, 1 = other-focused",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "temporalFocus": {
              "description": "Time orientation: 0 = past-dwelling, 0.5 = present, 1 = future-anticipating",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "source": {
          "description": "Provenance: which method produced this vector. Absent = direct vector input.",
          "type": "object",
          "properties": {
            "key": { "type": "string", "description": "Source method identifier (e.g. mira, hds, descriptive)" },
            "sourceData": { "description": "Raw observation from the source method" },
            "engineVersion": { "type": "string", "description": "Converter engine version used" },
            "modelVersion": { "type": "string", "description": "Model definition version used" }
          }
        }
      },
      "required": ["vectors"]
    },
    "message/system-alert": {
      "description": "Operator → user notification on app-system-out. Content: { level, title, body, ackRequired?, ackId? }. Plan 45.",
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "title", "body"],
      "properties": {
        "level": {
          "description": "Severity: info / warning / critical",
          "type": "string",
          "enum": ["info", "warning", "critical"]
        },
        "title": {
          "description": "Short heading (max 200 chars)",
          "type": "string",
          "maxLength": 200
        },
        "body": {
          "description": "Body text (max 4000 chars)",
          "type": "string",
          "maxLength": 4000
        },
        "ackRequired": {
          "description": "If true, the user's app surfaces an Acknowledge button and the operator expects a matching message/system-ack",
          "type": "boolean"
        },
        "ackId": {
          "description": "UUID generated by the operator at post time. Echoed in the matching message/system-ack to link the response.",
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "message/system-ack": {
      "description": "User → operator acknowledgement of a message/system-alert, paired by ackId. Plan 45.",
      "type": "object",
      "additionalProperties": false,
      "required": ["ackId", "ackedAt"],
      "properties": {
        "ackId": {
          "description": "Matches the message/system-alert.ackId being acknowledged",
          "type": "string",
          "format": "uuid"
        },
        "ackedAt": {
          "description": "ISO-8601 timestamp at which the user clicked Acknowledge",
          "type": "string",
          "format": "date-time"
        },
        "userNote": {
          "description": "Optional free-text note from the user (max 1000 chars)",
          "type": "string",
          "maxLength": 1000
        }
      }
    }
  },
  "extras": {
    "mass/mg": {
      "name": { "en": "Milligrams", "fr": "Milligrammes" },
      "symbol": "mg"
    },
    "mass/mcg": {
      "name": { "en": "Micrograms", "fr": "Microgrammes" },
      "symbol": "μg"
