{
  "version": "1.0.0",
  "types": {
    "vulva-mucus-inspect/v0": {
      "description": "DEPRECATED — use vulva-mucus-inspect/9d-vector with converter engine instead. Legacy simple enum kept for backward compatibility with existing data.",
      "type": "string",
      "enum": [
        "clear",
        "creamy",
        "dry-sticky",
        "egg-white"
      ]
    },
    "vulva-mucus-inspect/9d-vector": {
      "description": "Cervical fluid observation as a 9-dimensional vector. Content is { vectors, source? }. Used with the euclidian-distance converter engine.",
      "type": "object",
      "properties": {
        "vectors": {
          "description": "9-dimensional observation vector (each dimension 0.0–1.0)",
          "type": "object",
          "properties": {
            "threadiness": { "type": "number", "minimum": 0, "maximum": 1 },
            "stretchability": { "type": "number", "minimum": 0, "maximum": 1 },
            "lubricative": { "type": "number", "minimum": 0, "maximum": 1 },
            "transparency": { "type": "number", "minimum": 0, "maximum": 1 },
            "wetness": { "type": "number", "minimum": 0, "maximum": 1 },
            "densityFluidity": { "type": "number", "minimum": 0, "maximum": 1 },
            "sensation": { "type": "number", "minimum": 0, "maximum": 1 },
            "mucusVolume": { "type": "number", "minimum": 0, "maximum": 1 },
            "color": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "source": {
          "description": "Provenance: which method produced this vector. Absent = direct vector input.",
          "type": "object",
          "properties": {
            "key": { "type": "string", "description": "Source method identifier (e.g. mira, chartneo, creighton)" },
            "sourceData": { "description": "Raw observation from the source method" },
            "engineVersion": { "type": "string", "description": "Converter engine version used" },
            "modelVersion": { "type": "string", "description": "Model definition version used" }
          }
        }
      },
      "required": ["vectors"]
    },
    "contact/country": {
      "description": "Country",
      "type": "string"
    },
    "contact/name": {
      "description": "Name",
      "type": "string"
    },
    "contact/surname": {
      "description": "Surname",
      "type": "string"
    },
    "reproductive-sexuality/detailed": {
      "description": "Potentially reproductive sexual activity",
      "type": "string",
      "enum": [
        "fertile",
        "incomplete",
        "withdrawal",
        "condom",
        "cervical-barrier",
        "protected"
      ]
    },
    "ratio/proportion": {
      "description": "A proportion value from 0 to 1. Represents a fraction of a whole: 0 = none, 1 = maximum. Used for subjective scales (e.g. bleeding intensity) where reference points are defined by item options.",
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "test-result/scale": {
      "description": "Generic qualitative test result on a scale from -1 to 1. Negative values indicate a negative result, 0 indicates indeterminate, positive values indicate a positive result. The magnitude represents intensity or confidence. Common values: -1 (negative), 0 (indeterminate), 1 (positive). Intermediate values can represent semi-quantitative results (e.g., 0.5 for a weak positive). Applicable to any binary or semi-quantitative test: medical (OPK, pregnancy, COVID), environmental, industrial, etc.",
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "pregnancy/detailed": {
      "description": "Pregnancy. The value of `event.time` should indicate the start of pregnancy. When content value is 'ongoing' `event.duration` must be set to `null`. For any other value `event.duration` should be set to indicate when the pregnancy state terminated.",
      "type": "string",
      "enum": [
        "ongoing",
        "miscarriage",
        "ectopic",
        "stillbirth",
        "livebirth",
        "abortion"
      ]
    },
    "medication/basic": {
      "description": "Simple medication intake identified by free-text name. 'intake' follows the same structure as medication/coded-v1 for dose and route.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "description": "Free-text name of the medication",
          "type": "string"
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
    "medication/coded-v1": {
      "description": "Coded medication intake. 'drug' is the coded identity from datasets-service, 'intake' is the user-entered regimen. Maps to FHIR MedicationStatement: drug → medicationCodeableConcept, intake → dosage.",
      "type": "object",
      "required": ["drug"],
      "properties": {
        "drug": {
          "description": "Coded drug identity, populated from datasets-service selection. Contains multiple codes when the same drug is matched across coding systems.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized medication name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description (e.g. 'Aspirin 325 MG Oral Tablet')",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems. A single drug may have codes in RxNorm (prescribing), SNOMED-CT (clinical), and ATC (classification).",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": {
                    "description": "Code value (rxcui, SCTID, ATC code)",
                    "type": "string"
                  },
                  "system": {
                    "description": "Coding system: RxNorm, SNOMED-CT, ATC",
                    "type": "string"
                  },
                  "source": {
                    "description": "Data source reference",
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": {
                    "description": "Unique HDS identifier for this code entry",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
    "medication/prescription-v1": {
      "description": "Medication prescription. Captures what the doctor prescribed: drug identity, dosage, frequency, and instructions. event.duration reflects the full treatment period.",
      "type": "object",
      "required": ["drug"],
      "properties": {
        "drug": {
          "description": "Coded drug identity, populated from datasets-service selection.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized medication name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description (e.g. 'Aspirin 325 MG Oral Tablet')",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems.",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": { "type": "string" },
                  "system": { "type": "string" },
                  "source": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": { "type": "string" }
                }
              }
            }
          }
        },
        "posology": {
          "description": "Prescribed dosage and schedule",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            },
            "frequency": {
              "description": "Prescribed frequency (e.g. 2 times per day)",
              "$ref": "#/types/frequency~1times-period"
            },
            "asNeeded": {
              "description": "True if taken as needed (PRN) rather than on schedule",
              "type": "boolean"
            },
            "note": {
              "description": "Free text instructions (e.g. 'take with food', 'before bedtime')",
              "type": "string"
            }
          }
        }
      }
    },
    "treatment/basic": {
      "description": "Free-text treatment regimen. Used both for aggregate-intake (Flavour A: count > 0 captures lifetime history) and per-cycle/per-course capture (Flavour B). Treatment span uses Pryv's native event fields: event.time = treatment start, event.duration = span in seconds (omit for ongoing / unbounded). 'context' for the treatment (e.g. fertility, oncology) is carried by the event's streamId — see context-via-substream resolution.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "description": "Free-text name of the treatment / regimen (e.g. 'IVF', 'Chemotherapy', 'CBT')",
          "type": "string"
        },
        "count": {
          "description": "Aggregate intake count over the patient's lifetime. 0 = never. Use for Flavour A intake capture.",
          "type": "number"
        },
        "notes": {
          "description": "Free text supplementary notes",
          "type": "string"
        }
      }
    },
    "treatment/coded-v1": {
      "description": "Coded treatment regimen. 'regimen' is the coded identity from datasets-service (SNOMED-CT procedure / ICD-10-PCS / CPT). Treatment span uses Pryv's native event fields: event.time = treatment start, event.duration = span in seconds (omit for ongoing). Other payload fields mirror treatment/basic.",
      "type": "object",
      "required": ["regimen"],
      "properties": {
        "regimen": {
          "description": "Coded regimen identity, populated from datasets-service selection.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized regimen name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems (SNOMED-CT, ICD-10-PCS, CPT, …).",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": { "type": "string" },
                  "system": { "type": "string" },
                  "source": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": { "type": "string" }
                }
              }
            }
          }
        },
        "count": {
          "description": "Aggregate intake count over the patient's lifetime. 0 = never. Use for Flavour A intake capture.",
          "type": "number"
        },
        "notes": { "type": "string" }
      }
    },
    "procedure/basic": {
      "description": "Free-text clinical procedure (single dated event). When the procedure was performed is event.time (Pryv native); the procedure is treated as point-in-time (no event.duration). 'findings' is an open-vocabulary array describing procedure-bound observations (e.g. endometriosis localisation during a laparoscopy). Clinical-domain context (e.g. fertility) is carried by the event's streamId — see context-via-substream resolution.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "description": "Free-text name of the procedure (e.g. 'Laparoscopy', 'HSG', 'Polypectomy')",
          "type": "string"
        },
        "count": {
          "description": "Aggregate intake count (Flavour A: lifetime occurrences). 0 = never.",
          "type": "number"
        },
        "findings": {
          "description": "Open-vocabulary array of procedure-bound observations. Form preset declares which finding types are surfaced per procedure label.",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "description": "Finding category (e.g. 'endometriosis-localisation', 'adhesions', 'fibroid', 'modality').",
                "type": "string"
              },
              "value": {
                "description": "Finding value — string, boolean, or nested object as appropriate."
              },
              "notes": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
    "procedure/coded-v1": {
      "description": "Coded clinical procedure. 'procedure' is the coded identity from datasets-service. event.time = when the procedure was performed; point-in-time (no event.duration). Other payload fields mirror procedure/basic.",
      "type": "object",
      "required": ["procedure"],
      "properties": {
        "procedure": {
          "description": "Coded procedure identity, populated from datasets-service selection.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized procedure name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems (SNOMED-CT, ICD-10-PCS, CPT, …).",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": { "type": "string" },
                  "system": { "type": "string" },
                  "source": {
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": { "type": "string" }
                }
              }
            }
          }
        },
        "count": { "type": "number" },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string" },
              "value": {},
              "notes": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      }
    },
