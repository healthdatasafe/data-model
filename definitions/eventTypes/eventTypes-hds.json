{
  "version": "1.0.0",
  "types": {
    "vulva-mucus-inspect/v0": {
      "description": "DEPRECATED — use vulva-mucus-inspect/9d-vector with converter engine instead. Legacy simple enum kept for backward compatibility with existing data.",
      "type": "string",
      "enum": [
        "clear",
        "creamy",
        "dry-sticky",
        "egg-white"
      ]
    },
    "vulva-mucus-inspect/9d-vector": {
      "description": "Cervical fluid observation as a 9-dimensional vector. Content is { vectors, source? }. Used with the euclidian-distance converter engine.",
      "type": "object",
      "properties": {
        "vectors": {
          "description": "9-dimensional observation vector (each dimension 0.0–1.0)",
          "type": "object",
          "properties": {
            "threadiness": { "type": "number", "minimum": 0, "maximum": 1 },
            "stretchability": { "type": "number", "minimum": 0, "maximum": 1 },
            "lubricative": { "type": "number", "minimum": 0, "maximum": 1 },
            "transparency": { "type": "number", "minimum": 0, "maximum": 1 },
            "wetness": { "type": "number", "minimum": 0, "maximum": 1 },
            "densityFluidity": { "type": "number", "minimum": 0, "maximum": 1 },
            "sensation": { "type": "number", "minimum": 0, "maximum": 1 },
            "mucusVolume": { "type": "number", "minimum": 0, "maximum": 1 },
            "color": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "source": {
          "description": "Provenance: which method produced this vector. Absent = direct vector input.",
          "type": "object",
          "properties": {
            "key": { "type": "string", "description": "Source method identifier (e.g. mira, chartneo, creighton)" },
            "sourceData": { "description": "Raw observation from the source method" },
            "engineVersion": { "type": "string", "description": "Converter engine version used" },
            "modelVersion": { "type": "string", "description": "Model definition version used" }
          }
        }
      },
      "required": ["vectors"]
    },
    "contact/country": {
      "description": "Country",
      "type": "string"
    },
    "attributes/ethnicity": {
      "description": "Self-identified ethnicity / race category. US-style category set (OMB-aligned), recorded as a clinical / epidemiological variable.",
      "type": "string",
      "enum": [
        "american-indian-alaska-native",
        "asian",
        "black-african-american",
        "hispanic-latino",
        "middle-eastern-north-african",
        "native-hawaiian-pacific-islander",
        "white",
        "multiple",
        "other",
        "prefer-not-to-say"
      ]
    },
    "attributes/reproductive-stage": {
      "description": "Reproductive-aging / menopausal stage — a durable but time-varying patient attribute, aligned to the STRAW+10 staging system. Selects the reference band for stage-dependent hormones (estradiol, FSH, prolactin). Stage only; hormone therapy is recorded separately as a medication, not encoded here.",
      "type": "string",
      "enum": [
        "premenopausal",
        "perimenopausal",
        "postmenopausal",
        "surgical-menopause",
        "primary-ovarian-insufficiency",
        "pregnant",
        "postpartum",
        "lactating"
      ]
    },
    "fertility/tracking-method-v1": {
      "description": "Fertility-awareness charting method or device the person uses. Determines how their cycle observations should be interpreted.",
      "type": "string",
      "enum": [
        "billings",
        "creighton",
        "sympto-thermal",
        "marquette",
        "femm",
        "justisse",
        "peak-day",
        "clearblue",
        "mira",
        "inito",
        "oura",
        "kegg",
        "other"
      ]
    },
    "contact/name": {
      "description": "Name",
      "type": "string"
    },
    "contact/surname": {
      "description": "Surname",
      "type": "string"
    },
    "reproductive-sexuality/detailed": {
      "description": "Potentially reproductive sexual activity",
      "type": "string",
      "enum": [
        "fertile",
        "incomplete",
        "withdrawal",
        "condom",
        "cervical-barrier",
        "protected"
      ]
    },
    "ratio/proportion": {
      "description": "A proportion value from 0 to 1: 0 = none, 1 = maximum.",
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "test-result/scale": {
      "description": "Generic qualitative test result on a scale from -1 to 1. Negative values indicate a negative result, 0 indicates indeterminate, positive values indicate a positive result. The magnitude represents intensity or confidence. Common values: -1 (negative), 0 (indeterminate), 1 (positive). Intermediate values can represent semi-quantitative results (e.g., 0.5 for a weak positive). Applicable to any binary or semi-quantitative test: medical (OPK, pregnancy, COVID), environmental, industrial, etc.",
      "type": "number",
      "minimum": -1,
      "maximum": 1
    },
    "pregnancy/detailed": {
      "description": "Pregnancy. Use 'ongoing' while pregnancy is in progress; otherwise the value reflects how it terminated. 'very-early-loss' covers biochemical / pre-clinical losses with duration <6 weeks LMP (typically hCG-detected only, clinically distinct from miscarriage per ESHRE 2022 RPL guideline). 'molar' (hydatidiform mole) is a distinct entity from ectopic — abnormal trophoblastic tissue requiring hCG surveillance.",
      "type": "string",
      "enum": [
        "ongoing",
        "very-early-loss",
        "miscarriage",
        "ectopic",
        "molar",
        "stillbirth",
        "livebirth",
        "abortion"
      ]
    },
    "medication/basic": {
      "description": "Simple medication intake identified by free-text name. 'intake' follows the same structure as medication/coded-v1 for dose and route.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "description": "Free-text name of the medication",
          "type": "string"
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
    "medication/coded-v1": {
      "description": "Coded medication intake. 'drug' is the coded identity from datasets-service, 'intake' is the user-entered regimen. Maps to FHIR MedicationStatement: drug → medicationCodeableConcept, intake → dosage.",
      "type": "object",
      "required": ["drug"],
      "properties": {
        "drug": {
          "description": "Coded drug identity, populated from datasets-service selection. Contains multiple codes when the same drug is matched across coding systems.",
          "type": "object",
          "required": ["label", "codes"],
          "properties": {
            "label": {
              "description": "Localized medication name for display",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "description": {
              "description": "Localized full description (e.g. 'Aspirin 325 MG Oral Tablet')",
              "type": "object",
              "properties": {
                "en": { "type": "string" }
              }
            },
            "codes": {
              "description": "Coding identifiers across systems. A single drug may have codes in RxNorm (prescribing), SNOMED-CT (clinical), and ATC (classification).",
              "type": "array",
              "items": {
                "type": "object",
                "required": ["code", "system", "hdsId"],
                "properties": {
                  "code": {
                    "description": "Code value (rxcui, SCTID, ATC code)",
                    "type": "string"
                  },
                  "system": {
                    "description": "Coding system: RxNorm, SNOMED-CT, ATC",
                    "type": "string"
                  },
                  "source": {
                    "description": "Data source reference",
                    "type": "object",
                    "properties": {
                      "key": { "type": "string" }
                    }
                  },
                  "hdsId": {
                    "description": "Unique HDS identifier for this code entry",
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "intake": {
          "description": "User-entered intake regimen",
          "type": "object",
          "properties": {
            "doseValue": {
              "description": "Amount per intake (e.g. 2 for '2 tablets', 5 for '5 mL')",
              "type": "number"
            },
            "doseUnit": {
              "description": "HDS eventType reference for the dose unit",
              "type": "string",
              "enum": [
                "dose/tablet",
                "dose/drop",
                "dose/puff",
                "dose/application",
                "dose/suppository",
                "dose/unit",
                "volume/ml",
                "mass/mg",
                "mass/mcg",
                "mass/g"
              ]
            },
            "route": {
              "description": "Route of administration",
              "type": "string",
              "enum": [
                "oral",
                "sublingual",
                "parenteral",
                "intravenous",
                "intramuscular",
                "subcutaneous",
                "inhalation",
                "nasal",
                "topical",
                "transdermal",
                "ophthalmic",
                "otic",
                "rectal",
                "vaginal"
              ]
            }
          }
        }
      }
    },
