          "type": "string",
          "enum": ["h", "d", "wk", "mo", "y"]
        }
      }
    },
    "settings/preferred-locales": {
      "description": "User preferred locales, ordered by priority",
      "type": "array",
      "items": { "type": "string" }
    },
    "settings/theme": {
      "description": "UI theme preference",
      "type": "string",
      "enum": ["light", "dark"]
    },
